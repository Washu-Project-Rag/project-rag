# ---- Python ----
__pycache__/
*.pyc
.venv/
.env

# ---- macOS ----
.DS_Store

# ---- Large data (DO NOT COMMIT) ----
data/raw/wiki_dump/
data/raw/wiki_extracted/
data/chroma_db

# Ignore indexes (can be regenerated)
data/index/

# Ignore only selected large processed files
data/processed/first_round/wiki_cs_articles.jsonl
data/processed/corpus_chunks_filtered.jsonl
data/processed/second_round/wiki_cs_articles_v2.jsonl
data/processed/third_round/wiki_cs_articles_v3.jsonl

# Ignore everything else under raw by default...
data/raw/*
# ...but allow committing the small extracted sample
!data/raw/wiki_extracted_sample/
!data/raw/wiki_extracted_sample/*

# Ignore with token methods and results
data/processed/with_token/
src/ingest/filter_with_token/
src/ingest/visulization_filtering.ipynb
# Also ignore large archives
*.bz2
*.zip

# ---- Optional ----
*.log

# ---- Tools (do not commit vendored repos) ----
tools/