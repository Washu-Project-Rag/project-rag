# ---- Python ----
__pycache__/
*.pyc
.venv/
.env

# ---- macOS ----
.DS_Store

# ---- Large data (DO NOT COMMIT) ----
data/raw/wiki_dump/
data/raw/wiki_extracted/

# Ignore indexes (can be regenerated)
data/index/

# Ignore processed outputs by default...
data/processed/*
# ...but allow committing the filtered corpus file (plain or gz)
!data/processed/corpus_chunks.jsonl
!data/processed/corpus_chunks.jsonl.gz

# Ignore everything else under raw by default...
data/raw/*
# ...but allow committing the small extracted sample
!data/raw/wiki_extracted_sample/
!data/raw/wiki_extracted_sample/*

# Also ignore large archives
*.bz2
*.zip

# ---- Optional ----
*.log

# ---- Tools (do not commit vendored repos) ----
tools/